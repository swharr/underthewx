# ── Tempest WeatherFlow ───────────────────────────────
TEMPEST_API_TOKEN=your_personal_access_token_here
TEMPEST_STATION_ID=189439

# ── Weather Underground ───────────────────────────────
WU_API_KEY=your_wu_api_key_here
WU_STATION_ID=KUTLINDO32

# ── Azure Storage (Azurite for local dev) ────────────
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# ── Azure Key Vault (prod only — leave blank locally) ─
KEY_VAULT_URI=

# ── Location constants (rarely change) ───────────────
HOME_LAT=40.33307
HOME_LON=-111.72761
HOME_ELEVATION_FT=4623
HOME_FROST_DATE_SPRING=04-25
HOME_FROST_DATE_FALL=10-05
