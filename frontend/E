function UrlParamParser() {
    this.parameters = [];
    this.url = window.location.href;
    this.error;
    
    this.addParameter = function (pair) {
        var parameterKeyValue = pair.split("=");
        this.parameters[decodeURIComponent(parameterKeyValue[0])] = decodeURIComponent(parameterKeyValue[1]);
    }

    this.parseUrl = function() {
        var pairs = this.getKeyValuePairs();
        if(pairs === false) {
            return false;
        }

        for(var i=0; i<pairs.length; ++i) {
            this.addParameter(pairs[i]);
        }

        return true;
    }

    this.getStartPosition = function() {
        return this.url.indexOf('?') + 1;
    }

    this.getKeyValuePairs = function() {
        var options = this.url.slice(this.getStartPosition(), this.url.length);
        if(options === this.url || options === "") {
            this.error = "Invalid url to parse. Are there parameters?";
            return false;
        }
        return options.replace(/\+/g, " ").split("&");
    }
}function MchdUrl() {
    UrlParamParser.call(this);
    this.units;
    this.startDate;
