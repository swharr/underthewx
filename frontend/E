function MultSoilSubStations(stationId){
    AbnormalSoil.call(this,stationId);
    this.generateGridName = function(name){
        var re = new RegExp('[^_]*$');
        var subName = re.exec(name);
        this.gridTitle = this.oddDataType + ' ' + subName[0];
    }
    this.attachAbnormalVars = function(vars,config){
        varNames = new OddVarNames();
        for (var key in vars) {
            if (vars.hasOwnProperty(key)) {
                config.push({dataName:key,name:varNames.findVarName(key),order:mchd.hourlyConfig.length});
            }
        }
        this.sortOddStationHeaders(config);
    }

    this.generateGrid = function(data){
        subStations = this.parseSubStationHeader(data);
        json = JSON.parse(data);
        for (var i = subStations.length - 1; i >= 0; i--) {
            this.generateGridName(subStations[i][0][0]);
            this.createGrid();
            this.attachAbnormalVars(subStations[i].reduce(function(prev,curr){prev[curr[0]]=curr[1];return prev;},{}),mchd.oddVarsConfig);
            this.gridTitle = this.gridTitle.replace(/\s+/g, ''); 
            mchd.getOddVarsTable(station.gridTitle,true);
            // reset config
            mchd.oddVarsConfig = [{dataName:"date_time", name: "timestamp", order: 1}];
        }
    }

    this.createGrid = function(){
        ctn = $('.container-fluid').append('<div class="grid-ctn"><div>');
        ctn = ctn[0].lastChild;
        $('<h1>'+ this.gridTitle +'<h1>').appendTo(ctn); 
        this.gridTitle = this.gridTitle.replace(/\s+/g, ''); 
        $('<div id='+"thunder-grid-ctn-"+this.gridTitle+'></div>').appendTo(ctn); 
    }

    this.parseSubStationHeader = function(data){
        json = JSON.parse(data);
        data = Object.entries(json);
        var re = new RegExp('[^_]*$');
        var subs = new Array();
        var allSubs = new Array();
        for (var i = data.length - 1; i >= 0; i--) {
            var subName = re.exec(data[i][0]);
            if(subs.indexOf(subName[0]) == -1){
                subs.push(subName[0]);
            }
        }
        for (var i = subs.length - 1; i >= 0; i--) {
            arr = new Array();
            for (var j = data.length - 1; j >= 0; j--) {
                var subName = re.exec(data[j][0]);
                if(subs[i] == subName[0]){
                    arr.push(data[j]);
                }
            } 
            allSubs.push(arr);
        }
        return allSubs;
    }

    this.sortOddStationHeaders = function(config){
        config.sort(function(a,b){
            var re = new RegExp('[0-9]+');
            var x = re.exec(a.name);
            var y = re.exec(b.name);
            if(y == null || x == null){
                return 0;
            }
            x=parseInt(x[0]);
            y=parseInt(y[0]);
            if (x < y) {
                return -1;
            }
            if (x > y) {
                return 1;
            }
            return 0;
        });
    }
}

