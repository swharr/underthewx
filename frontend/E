function AbnormalSoil(stationId){
    AbnormalVars.call(this,stationId);
    this.oddDataType = 'Soil';
    this.sortOddStationHeaders = function(config){
        config.sort(function(a,b){
            var reA = /[^a-zA-Z]/g;
            var reN = /[^0-9]/g;

            var aA = a.name.replace(reA, "");
            var bA = b.name.replace(reA, "");
            if (aA === bA) {
                var aN = parseInt(a.name.replace(reN, ""), 10);
                var bN = parseInt(b.name.replace(reN, ""), 10);
                if(aN === bN){
                    return 0;
                }else if(aN > bN){
                    return 1;
                }else{
                    return -1;
                }
            } else {
                if(aA > bA){
                    return 1;
                }else{
                    return -1;
                }
            }
        });
    }
}
