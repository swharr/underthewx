    this.getParameterValue = function (pair) {
        split = pair.split("=");
        return decodeURIComponent(split[1]);
    }

    this.parseUrl = function() {
        this.parsed = MchdUrl.prototype.parseUrl.call(this);

        if(!this.parsed) {
            throw Error("Couldn't parse the url");
        }

        // sets all object attributes
        this.network = this.parameters["network"];
        this.stationId = this.parameters["station"];
        this.startDate = this.parameters["startdate"];
        this.endDate = this.parameters["enddate"];
        this.units = this.parameters["units"];
        this.showGraph = this.parameters["showgraph"];

        this.setStartAndEndDates();
    }

    this.setStartAndEndDates = function() {
        if(!this.startDate || !this.endDate) {
            var now = new Date();
            this.endDate = (new Date()).toISOString();
            this.startDate = (new Date(now - (30 * 24 * 60 * 60 * 1000))).toISOString();
        }
    }

    this.changeUrl = function(stationId, startDate, endDate, units, showGraph) {
        // get the same url up to "?"
        var currentUrl = window.location.href;
        currentUrl = currentUrl.slice(0,currentUrl.indexOf("?") + 1);
        if(currentUrl == "") {
            currentUrl = window.location.href + '?';
        }

        // add each new url variable
        currentUrl += ("network=" + this.network);

        // stationId
        if(stationId != 0) {
            currentUrl += ("&station=" + stationId);  
        } else {
            currentUrl += ("&station=" + this.stationId);
        }

        // startDate
        if(_startdate != 0){
            currentUrl += ("&startdate=" + startDate);
        } else{
            currentUrl += ("&startdate=" + this.startDate);  
        }

        // endDate
        if(_enddate != 0){
            currentUrl += ("&enddate=" + endDate);  
        } else{
          currentUrl += ("&enddate=" + this.endDate);  
        }

        // units
        if(_units != 0){
            currentUrl += ("&units=" + units);
        } else{
            currentUrl += ("&units=" + this.units);
        }

        // showGraph
        if(_showgraph   != 0){
            currentUrl += ("&showgraph=" + showGraph);
        } else{
            currentUrl += ("&showgraph=" + this.showGraph);
        }

        window.location.href = currentUrl;
    }
}
