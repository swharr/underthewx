    this.hlyAbnormal;
    this.stationInfo;
    this.failed = false;
    this.successHandler = successHandler;
    this.failHandler = failHandler;
    this.mchdCom = mchdCom;
    this.received = 0;
    this.totalToLoad = totalToLoad;

    this.abnormalSuccess;
    this.abnormalFail;

    var self = this;

    this.loadFrequencyData = function() {
        throw Error("Unimplemented abstract function loadData.");
    }

    this.loadFailed = function() {
        if(self.failed === false) {
            self.failed = true;
            self.failHandler();
        }
    }

    this.loadFailedIndependent = function() {
        self.loadIndependent("failed");
        if(self.failed === false) {
            self.failed = true;
            self.failHandler();
        }
    }

    this.loadStationInfoSucc = function(data){
        self.stationInfo = data;
        self.loadIndependent("station");
    }

    this.loadMinuteSuc = function(data) {
        self.minuteJson = data;
        self.loadIndependent("minute");
    }

    this.loadHourlySuc = function(data) {
        self.hourlyJson = data;
        self.loadIndependent("hourly");
    }

    this.loadDailySuc = function(data) {
        self.dailyJson = data;
        self.loadIndependent("daily");
    }

    this.loadIndependent = function(dataReceived) {
        if (dataReceived == "station") {
            self.received++;
        } else if (dataReceived == "minute") {
            self.received++;
        } else if (dataReceived == "hourly") {
            self.received++;
        } else if (dataReceived == "daily") {
            self.received++;
        } else if (dataReceived == "failed") {
            self.received++;
        }
        if (self.received == self.totalToLoad) {
            self.successHandler();
        }
    }
}
